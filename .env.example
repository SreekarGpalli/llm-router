# ─────────────────────────────────────────────────────────────────────────────
# LLM Router — Environment Configuration
# Copy this to .env and fill in the values.
# ─────────────────────────────────────────────────────────────────────────────

# REQUIRED — random secret, at least 32 characters.
# Used to: derive the Fernet key for encrypting upstream API keys,
#          sign session cookies, and encrypt the virtual API key for display.
# NEVER change after first run — stored encrypted keys will become unreadable.
SECRET_KEY=change-me-to-a-long-random-string

# REQUIRED — password to log into the web UI.
UI_PASSWORD=change-me-to-a-strong-password

# OPTIONAL — pre-generated virtual API key (set by install script on first run).
# If this is present and no key exists in the DB, this key will be stored on startup.
# The UI will display it because the app also stores an encrypted copy.
INITIAL_VIRTUAL_KEY=

# OPTIONAL — port Uvicorn listens on (default: 8000, accessed via CF Tunnel only)
PORT=8000

# OPTIONAL — path to the SQLite database file
DB_PATH=/opt/llm-router/data/router.db

# OPTIONAL — Cloudflare Tunnel public domain (shown in the UI Setup card)
CLOUDFLARE_DOMAIN=router.yourdomain.com
